#!/usr/bin/env bash

ROOT="$HOME/.memory"

shopt -s nullglob

render_base_context() {
  cat "$ROOT/profile.md" 2>/dev/null
  echo
  cat "$ROOT/preferences.md" 2>/dev/null
  echo
  cat "$ROOT/infra.md" 2>/dev/null
}

project_heading() {
  local file="$1" heading

  heading="$(grep -m1 '^# ' "$file" 2>/dev/null | sed 's/^# *//')"
  if [[ -n "$heading" ]]; then
    printf '%s\n' "$heading"
  else
    basename "$file" .md
  fi
}

project_description() {
  local file="$1" description

  # Fast path: prefer explicit one-line metadata.
  description="$(grep -m1 '^Description:[[:space:]]*[^[:space:]]' "$file" 2>/dev/null | sed 's/^Description:[[:space:]]*//')"
  if [[ -n "$description" ]]; then
    printf '%s\n' "$description"
    return
  fi

  # Compatibility path: support block Description and common overview-like sections.
  description="$(awk '
    /^Description:[[:space:]]*$/ {
      in_description=1
      next
    }
    in_description && /^[[:space:]]*$/ { next }
    in_description && /^#/ { next }
    in_description {
      print
      exit
    }

    /^\*\*(Goal|Type|Project Type|Overview)\*\*:[[:space:]]*/ {
      line=$0
      sub(/^\*\*[^*]+\*\*:[[:space:]]*/, "", line)
      if (line != "") {
        print line
        exit
      }
    }

    /^## (Overview|Purpose|Goal|Current Status|Core Features|Output|User Profile|Key Architecture|Tech Stack)/ {
      in_section=1
      next
    }
    in_section && /^[[:space:]]*$/ { next }
    in_section && /^## / { exit }
    in_section && /^[-*][[:space:]]/ { next }
    in_section && /^\*\*[^*]+\*\*:[[:space:]]*/ {
      line=$0
      sub(/^\*\*[^*]+\*\*:[[:space:]]*/, "", line)
      if (line != "") {
        print line
        exit
      }
    }
    in_section && $0 !~ /^#/ {
      print
      exit
    }
  ' "$file")"

  if [[ -n "$description" ]]; then
    printf '%s\n' "$description"
    return
  fi

  printf '%s\n' "No summary available yet."
}

project_github() {
  local file="$1"
  grep -m1 '^GitHub:' "$file" 2>/dev/null | sed 's/^GitHub: *//'
}

render_projects_summary() {
  local files=("$ROOT/projects/"*.md)
  local file name description github

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "(no project memory yet)"
    return
  fi

  for file in "${files[@]}"; do
    name="$(basename "$file" .md)"
    description="$(project_description "$file")"
    github="$(project_github "$file")"

    printf '%-20s %s' "$name" "$description"
    [[ -n "$github" ]] && printf '  (%s)' "$github"
    echo
  done
}

render_context() {
  render_base_context
  echo
  echo "Projects"
  echo
  render_projects_summary
}

expand_home_path() {
  local path="$1"
  if [[ "$path" == "~" ]]; then
    printf '%s\n' "$HOME"
    return
  fi
  if [[ "$path" == ~/* ]]; then
    printf '%s\n' "$HOME/${path#~/}"
    return
  fi
  printf '%s\n' "$path"
}

resolve_inject_project() {
  local requested="$1"
  local target=""
  local candidate
  local file
  local directory_field
  local expanded_dir

  if [[ -n "$requested" ]]; then
    target="$ROOT/projects/$requested.md"
    if [[ -f "$target" ]]; then
      printf '%s\n' "$requested"
      return 0
    fi
    return 1
  fi

  candidate="$(basename "$(pwd)")"
  if [[ -f "$ROOT/projects/$candidate.md" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  for file in "$ROOT/projects/"*.md; do
    directory_field="$(grep -m1 '^Directory:' "$file" 2>/dev/null | sed 's/^Directory:[[:space:]]*//')"
    [[ -n "$directory_field" ]] || continue
    expanded_dir="$(expand_home_path "$directory_field")"
    if [[ "$expanded_dir" == "$(pwd)" || "$expanded_dir" == "$(pwd -P)" ]]; then
      basename "$file" .md
      return 0
    fi
  done

  return 1
}

render_projects_quick_glance() {
  local limit="${1:-8}"
  local files=("$ROOT/projects/"*.md)
  local file
  local count=0
  local name
  local description
  local github

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "- (no project memory yet)"
    return
  fi

  for file in "${files[@]}"; do
    (( count += 1 ))
    if (( count > limit )); then
      echo "- ... (${#files[@]} total projects)"
      break
    fi
    name="$(basename "$file" .md)"
    description="$(project_description "$file")"
    github="$(project_github "$file")"
    printf -- '- %s: %s' "$name" "$description"
    [[ -n "$github" ]] && printf ' (%s)' "$github"
    echo
  done
}

write_copilot_project_summary() {
  local project_name="$1"
  local target_file="$2"
  local source_file="$ROOT/projects/$project_name.md"
  local max_lines=140
  local total_lines=0

  [[ -f "$source_file" ]] || return 1

  total_lines="$(wc -l < "$source_file" | tr -d ' ')"

  cat > "$target_file" << TEMPLATE_END
# Project Memory Snapshot

This file is auto-generated by \`ai-memory inject vs-code --scope project\` (or hybrid).
Do not edit manually - re-run inject to refresh.

Project: $project_name
Generated at: $(date '+%Y-%m-%d %H:%M:%S')

Source of truth remains runtime memory:
- \`ai-memory context\`
- \`ai-memory project $project_name\`

## Quick Facts

- Name: $project_name
- Description: $(project_description "$source_file")
- GitHub: $(project_github "$source_file")

## Project Snapshot (first $max_lines lines)

TEMPLATE_END

  sed -n "1,${max_lines}p" "$source_file" >> "$target_file"

  if (( total_lines > max_lines )); then
    echo >> "$target_file"
    echo "(truncated from ${total_lines} lines; run 'ai-memory project $project_name' for full details)" >> "$target_file"
  fi
}

print_generated_file_stats() {
  local file="$1"
  local bytes
  local approx_tokens

  [[ -f "$file" ]] || return 0

  bytes="$(wc -c < "$file" | tr -d ' ')"
  approx_tokens=$(( (bytes + 3) / 4 ))
  echo "  $(basename "$file"): ${bytes} bytes (~${approx_tokens} tokens)"
}

is_allowed_update_file() {
  local file="$1"

  [[ -n "$file" ]] || return 1
  [[ "$file" != /* ]] || return 1
  [[ "$file" != *".."* ]] || return 1

  case "$file" in
    profile.md|preferences.md|infra.md|projects/*.md)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_project_update_file() {
  [[ "$1" == projects/*.md ]]
}

require_command() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1
}

is_valid_config_key() {
  local key="$1"
  [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]
}

set_config_kv() {
  local file="$1" key="$2" val="$3" tmp

  tmp="$(mktemp)" || return 1
  if [[ -f "$file" ]]; then
    grep -v "^${key}=" "$file" > "$tmp" || true
  fi
  printf '%s=%s\n' "$key" "$val" >> "$tmp"
  mv "$tmp" "$file"
}

load_learn_modules() {
  local script_dir llm_module learn_module

  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  llm_module="$script_dir/lib/llm.sh"
  learn_module="$script_dir/lib/learn.sh"

  if [[ ! -f "$llm_module" ]]; then
    echo "Error: missing module: $llm_module" >&2
    return 1
  fi
  if [[ ! -f "$learn_module" ]]; then
    echo "Error: missing module: $learn_module" >&2
    return 1
  fi

  # shellcheck source=/dev/null
  source "$llm_module"
  # shellcheck source=/dev/null
  source "$learn_module"
}

cmd="$1"

case "$cmd" in

context)
  render_context
  ;;

infra)
  cat "$ROOT/infra.md"
  ;;

projects)
  render_projects_summary
  ;;

project)
  if [[ -z "$2" ]]; then
    echo "Usage: ai-memory project <name>" >&2
    exit 1
  fi
  target="$ROOT/projects/$2.md"
  if [[ ! -f "$target" ]]; then
    echo "Error: project '$2' not found at $target" >&2
    exit 1
  fi
  cat "$target"
  ;;

new-project)
  name="$2"
  if [[ -z "$name" ]]; then
    echo "Usage: ai-memory new-project <name>"
    exit 1
  fi
  target="$ROOT/projects/$name.md"
  if [[ -f "$target" ]]; then
    echo "Project '$name' already exists: $target"
    exit 1
  fi
  mkdir -p "$ROOT/projects"
  cat > "$target" << TEMPLATE_END
# $name

Description: <one-line summary of what this project does>

GitHub: https://github.com/<owner>/$name
Directory: ~/<path/to/$name>

## Purpose

<What problem does this project solve? Why does it exist?>

## How to Reference

<How should an AI use or invoke this project? e.g. CLI command, API, library import>

## Key Capabilities

- <capability 1>
- <capability 2>

## Tech Stack

- <language / framework>

## Notes

<Any caveats, known issues, or tips for AI agents>
TEMPLATE_END
  echo "Created: $target"
  echo "Edit the file to fill in project details."
  ;;

search)
  if [[ -z "$2" ]]; then
    echo "Usage: ai-memory search <keyword>" >&2
    exit 1
  fi
  grep -r -- "$2" "$ROOT"
  ;;

capability)
  echo "Memory capability:"
  echo "  Provides unified developer context from profile, preferences, infra, and projects."
  echo "  Use 'ai-memory project <name>' to view a project file."
  echo ""
  echo "Project summaries:"
  render_projects_summary
  ;;

inject)
  if [[ -z "$2" ]]; then
    echo "Usage: ai-memory inject <tool>" >&2
    exit 1
  fi
  tool="$2"
  shift 2

  case "$tool" in
  claude)
    context_content="$(render_context)"
    target="$(pwd)/CLAUDE.md"
    cat > "$target" << 'TEMPLATE_END'
# Developer Memory Context

This file is auto-generated by `ai-memory inject claude`.
Do not edit manually — re-run the command to refresh.

Read the developer memory before planning any solution:

```bash
ai-memory context     # developer profile + preferences + infra + project summaries
ai-memory project <name>  # full details for a specific project
ai-memory capability  # system overview
```

## Current Context

TEMPLATE_END
    echo "$context_content" >> "$target"
    echo "Injected into: $target"
    ;;

  opencode)
    context_content="$(render_context)"
    target_dir="$(pwd)/.opencode"
    target="$target_dir/instructions.md"
    mkdir -p "$target_dir"
    cat > "$target" << 'TEMPLATE_END'
# Developer Memory Context

This file is auto-generated by `ai-memory inject opencode`.
Do not edit manually — re-run the command to refresh.

Read the developer memory before planning any solution:

```bash
ai-memory context     # developer profile + preferences + infra + project summaries
ai-memory project <name>  # full details for a specific project
ai-memory capability  # system overview
```

## Current Context

TEMPLATE_END
    echo "$context_content" >> "$target"
    echo "Injected into: $target"
    ;;

  codex)
    context_content="$(render_context)"
    target="$(pwd)/.codex-instructions.md"
    cat > "$target" << 'TEMPLATE_END'
# Developer Memory Context

This file is auto-generated by `ai-memory inject codex`.
Do not edit manually — re-run the command to refresh.

Use with: codex --instructions "$(cat .codex-instructions.md)"

Or load memory directly:
  codex --instructions "$(ai-memory context)"

## Current Context

TEMPLATE_END
    echo "$context_content" >> "$target"
    echo "Injected into: $target"
    echo "Usage: codex --instructions \"\$(cat .codex-instructions.md)\""
    ;;

  vs-code|copilot)
    inject_scope="global"
    requested_project=""
    resolved_project=""
    target_dir="$(pwd)/.github"
    target_main="$target_dir/copilot-instructions.md"
    target_project="$target_dir/copilot-project-summary.md"

    while [[ $# -gt 0 ]]; do
      case "$1" in
      --scope)
        if [[ -z "$2" ]]; then
          echo "Error: --scope requires a value (global|project|hybrid)" >&2
          exit 1
        fi
        inject_scope="$2"
        shift 2
        ;;
      --project)
        if [[ -z "$2" ]]; then
          echo "Error: --project requires a project name" >&2
          exit 1
        fi
        requested_project="$2"
        shift 2
        ;;
      *)
        echo "Usage: ai-memory inject vs-code [--scope global|project|hybrid] [--project <name>]" >&2
        exit 1
        ;;
      esac
    done

    case "$inject_scope" in
      global|project|hybrid)
        ;;
      *)
        echo "Error: invalid scope '$inject_scope' (expected: global|project|hybrid)" >&2
        exit 1
        ;;
    esac

    if [[ "$inject_scope" != "global" ]]; then
      resolved_project="$(resolve_inject_project "$requested_project")" || {
        echo "Warning: unable to resolve current project memory; falling back to global scope." >&2
        inject_scope="global"
      }
    fi

    mkdir -p "$target_dir"
    cat > "$target_main" << TEMPLATE_END
# Developer Memory Context (Dynamic)

This file is auto-generated by \`ai-memory inject vs-code\`.
Do not edit manually - re-run the command to refresh.

Mode: $inject_scope

For VS Code Copilot, prefer dynamic context over static snapshots.

Always start by reading runtime memory, not this file content:

\`ai-memory context\`

For project-specific tasks, run:

\`ai-memory project <name>\`

To view memory-system capabilities, run:

\`ai-memory capability\`

Rules for AI assistants:
- Treat \`ai-memory context\` as the default source of truth.
- Do not assume this file contains the latest runtime memory.
- Use project files (\`projects/*.md\`) as the only source for project-specific memory.

TEMPLATE_END

    if [[ "$inject_scope" == "project" || "$inject_scope" == "hybrid" ]]; then
      write_copilot_project_summary "$resolved_project" "$target_project" || {
        echo "Warning: failed to generate $target_project; continuing with main instructions only." >&2
      }

      cat >> "$target_main" << TEMPLATE_END

Project summary snapshot:
- Preferred project: $resolved_project
- Read: .github/copilot-project-summary.md
- Treat snapshot as helper only; runtime memory stays authoritative.
TEMPLATE_END
    else
      if [[ -f "$target_project" ]]; then
        rm -f "$target_project"
      fi
    fi

    if [[ "$inject_scope" == "hybrid" ]]; then
      cat >> "$target_main" << TEMPLATE_END

Quick project glance (lightweight index):
TEMPLATE_END
      render_projects_quick_glance 8 >> "$target_main"
    fi

    cat >> "$target_main" << TEMPLATE_END

Regeneration:
- Refresh this file after memory updates: \`ai-memory inject vs-code --scope $inject_scope\`
TEMPLATE_END

    echo "Injected into: $target_main"
    if [[ -f "$target_project" ]]; then
      echo "Injected into: $target_project"
    fi
    echo "Generated file stats:"
    print_generated_file_stats "$target_main"
    print_generated_file_stats "$target_project"
    ;;

  *)
    echo "Usage: ai-memory inject <tool>" >&2
    echo ""
    echo "Supported tools:" >&2
    echo "  claude    - generates CLAUDE.md in current directory" >&2
    echo "  opencode  - generates .opencode/instructions.md in current directory" >&2
    echo "  codex     - generates .codex-instructions.md in current directory" >&2
    echo "  vs-code   - generates .github/copilot-instructions.md in current directory" >&2
    echo "              options: --scope global|project|hybrid [--project <name>]" >&2
    exit 1
    ;;
  esac
  ;;

config)
  config_file="$ROOT/.llm-config"
  case "$2" in
  show)
    if [[ -f "$config_file" ]]; then
      cat "$config_file"
      if ! grep -q '^AUTO_INJECT_VSCODE=' "$config_file"; then
        echo "AUTO_INJECT_VSCODE=0"
      fi
    else
      echo "(no config - defaults in effect)"
      echo "LLM_URL=https://api.openai.com/v1/chat/completions"
      echo "LLM_MODEL=gpt-4o-mini"
      echo "LLM_KEY_ENV=OPENAI_API_KEY"
      echo "AUTO_INJECT_VSCODE=0"
    fi
    ;;
  set)
    mkdir -p "$ROOT"
    if [[ $# -lt 3 ]]; then
      echo "Usage: ai-memory config set LLM_URL=... LLM_MODEL=... LLM_KEY_ENV=..." >&2
      exit 1
    fi
    shift 2
    for pair in "$@"; do
      if [[ "$pair" != *=* ]]; then
        echo "Invalid config pair: $pair (expected KEY=VALUE)" >&2
        exit 1
      fi
      key="${pair%%=*}"
      val="${pair#*=}"
      if ! is_valid_config_key "$key"; then
        echo "Invalid config key: $key" >&2
        exit 1
      fi
      set_config_kv "$config_file" "$key" "$val" || {
        echo "Error: failed to update config file: $config_file" >&2
        exit 1
      }
    done
    echo "Config updated: $config_file"
    ;;
  *)
    echo "Usage: ai-memory config show"
    echo "       ai-memory config set LLM_URL=... LLM_MODEL=... LLM_KEY_ENV=..."
    echo ""
    echo "Examples:"
    echo "  ai-memory config set LLM_KEY_ENV=DEEPSEEK_API_KEY LLM_URL=https://api.deepseek.com/v1/chat/completions LLM_MODEL=deepseek-chat"
    echo "  ai-memory config set LLM_KEY_ENV=ANTHROPIC_API_KEY LLM_URL=https://api.anthropic.com/v1/chat/completions LLM_MODEL=claude-3-5-haiku-20241022"
    echo "  ai-memory config set AUTO_INJECT_VSCODE=1"
    ;;
  esac
  ;;

learn)
  load_learn_modules || exit 1
  run_learn "${@:2}"
  ;;

*)
  echo "ai-memory commands:"
  echo "  ai-memory context"
  echo "  ai-memory infra"
  echo "  ai-memory projects"
  echo "  ai-memory project <name>"
  echo "  ai-memory new-project <name>"
  echo "  ai-memory capability"
  echo "  ai-memory search <keyword>"
  echo "  ai-memory inject <tool>    (claude | opencode | codex | vs-code)"
  echo "      vs-code options: --scope global|project|hybrid [--project <name>]"
  echo "  ai-memory config show"
  echo "  ai-memory config set LLM_URL=... LLM_MODEL=... LLM_KEY_ENV=..."
  echo "  ai-memory learn [<file>|-]  (use - or omit for stdin)"
  echo "  ai-memory learn --dry-run [<file>|-]"
  ;;
esac