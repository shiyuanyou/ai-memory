#!/usr/bin/env bash

ROOT="$HOME/.memory"

shopt -s nullglob

render_base_context() {
  cat "$ROOT/profile.md" 2>/dev/null
  echo
  cat "$ROOT/preferences.md" 2>/dev/null
  echo
  cat "$ROOT/infra.md" 2>/dev/null
}

project_heading() {
  local file="$1" heading

  heading="$(grep -m1 '^# ' "$file" 2>/dev/null | sed 's/^# *//')"
  if [[ -n "$heading" ]]; then
    printf '%s\n' "$heading"
  else
    basename "$file" .md
  fi
}

project_description() {
  local file="$1" description

  description="$(grep -m1 '^Description:' "$file" 2>/dev/null | sed 's/^Description: *//')"
  if [[ "$description" == "Description:" || -z "$description" ]]; then
    description="$(awk '
      /^Description:[[:space:]]*$/ {
        waiting=1
        next
      }
      waiting && /^[[:space:]]*$/ { next }
      waiting && /^#/ { next }
      waiting {
        print
        exit
      }
    ' "$file")"
  fi

  if [[ -n "$description" ]]; then
    printf '%s\n' "$description"
    return
  fi

  description="$(awk '
    /^\*\*(Goal|Type|Project Type|Overview)\*\*:[[:space:]]*/ {
      line=$0
      sub(/^\*\*[^*]+\*\*:[[:space:]]*/, "", line)
      if (line != "") {
        print line
        exit
      }
    }
    /^## (Overview|Purpose|Goal|Current Status|Core Features|Output|User Profile|Key Architecture|Tech Stack)/ {
      in_section=1
      next
    }
    in_section && /^[[:space:]]*$/ { next }
    in_section && /^## / { exit }
    in_section && /^[-*][[:space:]]/ { next }
    in_section && /^\*\*[^*]+\*\*:[[:space:]]*/ {
      line=$0
      sub(/^\*\*[^*]+\*\*:[[:space:]]*/, "", line)
      if (line != "") {
        print line
        exit
      }
    }
    in_section && $0 !~ /^#/ {
      print
      exit
    }
  ' "$file")"

  if [[ -n "$description" ]]; then
    printf '%s\n' "$description"
  else
    printf '%s\n' "No summary available yet."
  fi
}

project_github() {
  local file="$1"
  grep -m1 '^GitHub:' "$file" 2>/dev/null | sed 's/^GitHub: *//'
}

render_projects_summary() {
  local files=("$ROOT/projects/"*.md)
  local file name description github

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "(no project memory yet)"
    return
  fi

  for file in "${files[@]}"; do
    name="$(basename "$file" .md)"
    description="$(project_description "$file")"
    github="$(project_github "$file")"

    printf '%-20s %s' "$name" "$description"
    [[ -n "$github" ]] && printf '  (%s)' "$github"
    echo
  done
}

render_context() {
  render_base_context
  echo
  echo "Projects"
  echo
  render_projects_summary
}

is_allowed_update_file() {
  local file="$1"

  [[ -n "$file" ]] || return 1
  [[ "$file" != /* ]] || return 1
  [[ "$file" != *".."* ]] || return 1

  case "$file" in
    profile.md|preferences.md|infra.md|projects/*.md)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_project_update_file() {
  [[ "$1" == projects/*.md ]]
}

_llm_call() {
  local system="$1" prompt="$2"
  local config="$ROOT/.llm-config"
  local url model key_env api_key

  url="$(grep '^LLM_URL=' "$config" 2>/dev/null | cut -d= -f2-)"
  model="$(grep '^LLM_MODEL=' "$config" 2>/dev/null | cut -d= -f2-)"
  key_env="$(grep '^LLM_KEY_ENV=' "$config" 2>/dev/null | cut -d= -f2-)"

  url="${url:-https://api.openai.com/v1/chat/completions}"
  model="${model:-gpt-4o-mini}"
  key_env="${key_env:-OPENAI_API_KEY}"
  api_key="${!key_env}"

  if [[ -z "$api_key" ]]; then
    echo "Error: \$$key_env is not set." >&2
    echo "  Run: ai-memory config set LLM_KEY_ENV=YOUR_KEY_VAR_NAME" >&2
    return 1
  fi

  curl -sf "$url" \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    -d "$(jq -n --arg m "$model" --arg s "$system" --arg u "$prompt" \
      '{model:$m,messages:[{role:"system",content:$s},{role:"user",content:$u}]}')" \
  | jq -r '.choices[0].message.content'
}

cmd="$1"

case "$cmd" in

context)
  render_context
  ;;

infra)
  cat $ROOT/infra.md
  ;;

projects)
  render_projects_summary
  ;;

project)
  if [[ -z "$2" ]]; then
    echo "Usage: ai-memory project <name>"
    exit 1
  fi
  cat "$ROOT/projects/$2.md"
  ;;

new-project)
  name="$2"
  if [[ -z "$name" ]]; then
    echo "Usage: ai-memory new-project <name>"
    exit 1
  fi
  target="$ROOT/projects/$name.md"
  if [[ -f "$target" ]]; then
    echo "Project '$name' already exists: $target"
    exit 1
  fi
  mkdir -p "$ROOT/projects"
  cat > "$target" << TEMPLATE_END
# $name

Description: <one-line summary of what this project does>

GitHub: https://github.com/<owner>/$name
Directory: ~/<path/to/$name>

## Purpose

<What problem does this project solve? Why does it exist?>

## How to Reference

<How should an AI use or invoke this project? e.g. CLI command, API, library import>

## Key Capabilities

- <capability 1>
- <capability 2>

## Tech Stack

- <language / framework>

## Notes

<Any caveats, known issues, or tips for AI agents>
TEMPLATE_END
  echo "Created: $target"
  echo "Edit the file to fill in project details."
  ;;

search)
  grep -r "$2" $ROOT
  ;;

capability)
  echo "Memory capability:"
  echo "  Provides unified developer context from profile, preferences, infra, and projects."
  echo "  Use 'ai-memory project <name>' to view a project file."
  echo ""
  echo "Project summaries:"
  render_projects_summary
  ;;

inject)
  tool="$2"
  context_content="$(render_context)"

  case "$tool" in
  claude)
    target="$(pwd)/CLAUDE.md"
    cat > "$target" << 'TEMPLATE_END'
# Developer Memory Context

This file is auto-generated by `ai-memory inject claude`.
Do not edit manually — re-run the command to refresh.

Read the developer memory before planning any solution:

```bash
ai-memory context     # developer profile + preferences + infra + project summaries
ai-memory project <name>  # full details for a specific project
ai-memory capability  # system overview
```

## Current Context

TEMPLATE_END
    echo "$context_content" >> "$target"
    echo "Injected into: $target"
    ;;

  opencode)
    target_dir="$(pwd)/.opencode"
    target="$target_dir/instructions.md"
    mkdir -p "$target_dir"
    cat > "$target" << 'TEMPLATE_END'
# Developer Memory Context

This file is auto-generated by `ai-memory inject opencode`.
Do not edit manually — re-run the command to refresh.

Read the developer memory before planning any solution:

```bash
ai-memory context     # developer profile + preferences + infra + project summaries
ai-memory project <name>  # full details for a specific project
ai-memory capability  # system overview
```

## Current Context

TEMPLATE_END
    echo "$context_content" >> "$target"
    echo "Injected into: $target"
    ;;

  codex)
    target="$(pwd)/.codex-instructions.md"
    cat > "$target" << 'TEMPLATE_END'
# Developer Memory Context

This file is auto-generated by `ai-memory inject codex`.
Do not edit manually — re-run the command to refresh.

Use with: codex --instructions "$(cat .codex-instructions.md)"

Or load memory directly:
  codex --instructions "$(ai-memory context)"

## Current Context

TEMPLATE_END
    echo "$context_content" >> "$target"
    echo "Injected into: $target"
    echo "Usage: codex --instructions \"\$(cat .codex-instructions.md)\""
    ;;

  *)
    echo "Usage: ai-memory inject <tool>"
    echo ""
    echo "Supported tools:"
    echo "  claude    — generates CLAUDE.md in current directory"
    echo "  opencode  — generates .opencode/instructions.md in current directory"
    echo "  codex     — generates .codex-instructions.md in current directory"
    ;;
  esac
  ;;

config)
  config_file="$ROOT/.llm-config"
  case "$2" in
  show)
    if [[ -f "$config_file" ]]; then
      cat "$config_file"
    else
      echo "(no config — defaults in effect)"
      echo "LLM_URL=https://api.openai.com/v1/chat/completions"
      echo "LLM_MODEL=gpt-4o-mini"
      echo "LLM_KEY_ENV=OPENAI_API_KEY"
    fi
    ;;
  set)
    mkdir -p "$ROOT"
    shift 2
    for pair in "$@"; do
      key="${pair%%=*}"
      val="${pair#*=}"
      if grep -q "^${key}=" "$config_file" 2>/dev/null; then
        sed -i '' "s|^${key}=.*|${key}=${val}|" "$config_file"
      else
        echo "${key}=${val}" >> "$config_file"
      fi
    done
    echo "Config updated: $config_file"
    ;;
  *)
    echo "Usage: ai-memory config show"
    echo "       ai-memory config set LLM_URL=... LLM_MODEL=... LLM_KEY_ENV=..."
    echo ""
    echo "Examples:"
    echo "  ai-memory config set LLM_KEY_ENV=DEEPSEEK_API_KEY LLM_URL=https://api.deepseek.com/v1/chat/completions LLM_MODEL=deepseek-chat"
    echo "  ai-memory config set LLM_KEY_ENV=ANTHROPIC_API_KEY LLM_URL=https://api.anthropic.com/v1/chat/completions LLM_MODEL=claude-3-5-haiku-20241022"
    ;;
  esac
  ;;

learn)
  dry_run=0
  input_arg="$2"

  if [[ "$2" == "--dry-run" ]]; then
    dry_run=1
    input_arg="$3"
  fi

  if [[ -n "$input_arg" && "$input_arg" != "-" ]]; then
    [[ ! -f "$input_arg" ]] && echo "Error: file not found: $input_arg" >&2 && exit 1
    input="$(cat "$input_arg")"
  else
    input="$(cat)"
  fi

  current="$(render_context)"

  system='You are a developer memory manager. Extract facts worth remembering from the new information provided.
Output ONLY valid JSON (no markdown fences, no explanation):
{
  "updates": [
    {"file": "profile.md", "action": "append", "content": "..."}
  ]
}
Supported files: profile.md, preferences.md, infra.md, projects/<name>.md
Actions: "append" adds text to end of file. "replace" rewrites the full file.
Rules:
- Project-specific facts, project status, project capabilities, and project roadmaps must only go to projects/<name>.md.
- Do not store project lists or project summaries in profile.md, preferences.md, or infra.md.
- profile.md is for developer identity and technical background only.
- preferences.md is for coding preferences and constraints only.
- infra.md is for infrastructure, domains, services, and environments only.
Skip trivial or already-known facts. Be concise. If nothing is worth remembering, return {"updates":[]}'

  user="Current memory:
${current}

New information to learn:
${input}"

  echo "Analyzing..." >&2
  response="$(_llm_call "$system" "$user")" || exit 1

  # Strip markdown code fences if model wraps response
  response="$(printf '%s' "$response" | sed '/^```/d')"

  n="$(jq '.updates | length' <<< "$response" 2>/dev/null)"
  if [[ -z "$n" || "$n" == "0" || "$n" == "null" ]]; then
    echo "Nothing new to remember."
    exit 0
  fi

  if [[ "$dry_run" -eq 1 ]]; then
    echo "Dry run mode: no files will be modified."
  fi

  for i in $(seq 0 $((n - 1))); do
    file="$(jq -r ".updates[$i].file" <<< "$response")"
    action="$(jq -r ".updates[$i].action" <<< "$response")"
    content="$(jq -r ".updates[$i].content" <<< "$response")"

    if ! is_allowed_update_file "$file"; then
      echo "  invalid target '$file' — skipped"
      continue
    fi

    case "$action" in
      append|replace)
        ;;
      *)
        echo "  unknown action '$action' for $file — skipped"
        continue
        ;;
    esac

    if ! is_project_update_file "$file" && grep -Eiq '(^# )|(^Description:)|(^GitHub:)|(^Directory:)|(^## )' <<< "$content"; then
      echo "  project-like content targeted $file — skipped"
      continue
    fi

    target="$ROOT/$file"

    if [[ "$dry_run" -eq 1 ]]; then
      echo "  [dry-run] $action → $file"
      continue
    fi

    mkdir -p "$(dirname "$target")"
    case "$action" in
    append)
      printf '\n%s\n' "$content" >> "$target"
      echo "  appended → $file"
      ;;
    replace)
      printf '%s\n' "$content" > "$target"
      echo "  replaced → $file"
      ;;
    esac
  done
  echo "Memory updated."
  ;;

*)
  echo "ai-memory commands:"
  echo "  ai-memory context"
  echo "  ai-memory infra"
  echo "  ai-memory projects"
  echo "  ai-memory project <name>"
  echo "  ai-memory new-project <name>"
  echo "  ai-memory capability"
  echo "  ai-memory search <keyword>"
  echo "  ai-memory inject <tool>    (claude | opencode | codex)"
  echo "  ai-memory config show"
  echo "  ai-memory config set LLM_URL=... LLM_MODEL=... LLM_KEY_ENV=..."
  echo "  ai-memory learn [<file>|-]  (use - or omit for stdin)"
  echo "  ai-memory learn --dry-run [<file>|-]"
  ;;
esac