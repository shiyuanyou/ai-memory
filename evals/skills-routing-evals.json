{
  "suite": "skills-routing",
  "description": "Prompts for validating first-turn routing in new-window and subagent scenarios.",
  "thresholds": {
    "new_window": 0.8,
    "subagent": 0.85
  },
  "evals": [
    {
      "id": "intro-project",
      "prompt": "简单介绍一下这个项目",
      "expected": [
        "Mentions ai-memory project goal",
        "Uses a narrow read path",
        "Avoids broad snapshot dumping"
      ]
    },
    {
      "id": "static-snapshot",
      "prompt": "为什么你们不用静态大快照写 copilot-instructions?",
      "expected": [
        "Explains dynamic source of truth",
        "Mentions token/staleness tradeoff",
        "Keeps read set minimal"
      ]
    },
    {
      "id": "inject-optimization",
      "prompt": "帮我改 inject 逻辑，支持更省 token 的模式",
      "expected": [
        "Routes to inject/instructions logic",
        "Mentions global/project/hybrid or equivalent",
        "Avoids irrelevant files"
      ]
    },
    {
      "id": "learn-staleness",
      "prompt": "分析 learn 流程是否会导致上下文过期",
      "expected": [
        "Routes to learn pipeline",
        "Discusses refresh/inject linkage",
        "References runtime memory freshness"
      ]
    },
    {
      "id": "token-audit",
      "prompt": "评估这个仓库的 token 开销结构",
      "expected": [
        "Routes to token audit skill or equivalent",
        "Mentions instructions vs skills split",
        "Provides bounded optimization advice"
      ]
    },
    {
      "id": "project-vs-skill",
      "prompt": "为什么要把 memory 设计成 skills 按需加载，而不是全塞进 instructions?",
      "expected": [
        "Explains on-demand loading rationale",
        "Mentions token and routing tradeoff",
        "Keeps project facts separate from main instructions"
      ]
    },
    {
      "id": "repo-entrypoints",
      "prompt": "这个仓库我应该先看哪些文件？",
      "expected": [
        "Mentions minimal entrypoint files",
        "Uses project-context routing",
        "Avoids broad repository dump"
      ]
    },
    {
      "id": "hybrid-usage",
      "prompt": "什么时候应该用 inject --scope hybrid？",
      "expected": [
        "Explains hybrid usage boundary",
        "Mentions project-heavy sessions",
        "Contrasts with global mode"
      ]
    },
    {
      "id": "project-resolution",
      "prompt": "为什么 hybrid 有时会回退到 global？",
      "expected": [
        "Mentions project resolution priority",
        "Mentions runtime/global memory missing case",
        "Gives concrete mitigation"
      ]
    },
    {
      "id": "repo-local-fallback",
      "prompt": "repo-local project memory 的作用是什么？",
      "expected": [
        "Explains fallback role",
        "Explains relation to ~/.memory/projects",
        "Keeps runtime source-of-truth distinction"
      ]
    }
  ]
}
